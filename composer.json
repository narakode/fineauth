{
    "name": "narakode/fineauth",
    "description": "A simple authentication package for Laravel REST APIs.",
    "type": "library",
    "authors": [
        {
            "name": "ibrahimalanshor",
            "email": "ibrahimalanshor6@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Narakode\\FineAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Narakode\\FineAuth\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Narakode\\FineAuth\\FineAuthServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": [
            "@clear",
            "@php vendor/bin/pest"
        ]
    },
    "require": {
        "php": "^8.3",
        "laravel/sanctum": "^4.3",
        "laravel/framework": "^13.0"
    }
}
