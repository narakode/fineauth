{
    "name": "narakode/fineauth",
    "description": "Fine Auth",
    "type": "library",
    "authors": [
        {
            "name": "ibrahimalanshor",
            "email": "ibrahimalanshor6@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Narakode\\FineAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Narakode\\FineAuth\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.7"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Narakode\\FineAuth\\FineAuthServiceProvider"
            ]
        }
    }
}
